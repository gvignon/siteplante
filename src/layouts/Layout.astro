---
interface Props { titre: string; description?: string; showHeader?: boolean; }
const {
  titre,
  description = "Plantes comestibles sauvages et cultivées : fiches, saisons, recettes et précautions.",
  showHeader = true,
} = Astro.props;

const brandSvg = `<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Recette Sauvage">
  <defs>
    <linearGradient id="rsPink" x1="0" y1="1" x2="1" y2="0"><stop offset="0" stop-color="#f9a8d4"/><stop offset="1" stop-color="#ec4899"/></linearGradient>
    <linearGradient id="rsBlue" x1="0" y1="1" x2="1" y2="0"><stop offset="0" stop-color="#60a5fa"/><stop offset="1" stop-color="#4f6ef7"/></linearGradient>
  </defs>
  <rect x="1.5" y="1.5" width="45" height="45" rx="13.5" fill="#111a37"/>
  <rect x="22.8" y="13" width="2.4" height="26" rx="1.2" fill="#fff"/>
  <g fill="url(#rsPink)"><g transform="translate(23.4,31) rotate(-44)"><path d="M0 0 C 4 -4 4 -10 0 -14 C -4 -10 -4 -4 0 0 Z"/></g><g transform="translate(23.4,23.5) rotate(-44)"><path d="M0 0 C 3.2 -3.2 3.2 -8 0 -11.4 C -3.2 -8 -3.2 -3.2 0 0 Z"/></g></g>
  <g fill="url(#rsBlue)"><g transform="translate(24.6,31) rotate(44)"><path d="M0 0 C 4 -4 4 -10 0 -14 C -4 -10 -4 -4 0 0 Z"/></g><g transform="translate(24.6,23.5) rotate(44)"><path d="M0 0 C 3.2 -3.2 3.2 -8 0 -11.4 C -3.2 -8 -3.2 -3.2 0 0 Z"/></g></g>
  <g transform="translate(24,14.5)" fill="url(#rsBlue)"><path d="M0 0 C 2.8 -3 2.8 -7.5 0 -10.5 C -2.8 -7.5 -2.8 -3 0 0 Z"/></g>
</svg>`;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{titre} — Recette Sauvage</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Spectral:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    {showHeader && (
      <header class="site-nav">
        <div class="site-nav__inner">
          <a href="/" class="brand">
            <span class="brand__logo" set:html={brandSvg} />
            <span class="brand__txt">
              <span class="brand__name">Recette <span class="brand__name--accent">Sauvage</span></span>
              <span class="brand__tag">cuisine des plantes sauvages</span>
            </span>
          </a>
          <nav class="site-links">
            <a href="/">Accueil</a>
            <a href="/plantes/">Les plantes</a>
            <a href="/familles/">Familles</a>
            <a href="/faune/">La faune</a>
          </nav>
        </div>
      </header>
    )}

    <slot />

    <footer class="site-footer">
      <div class="site-footer__inner">
        <p class="avert">⚠️ Site informatif. La cueillette comporte des risques. En cas de doute sur l'identification d'une plante, ne jamais la consommer.</p>
        <div class="site-footer__brand">
          <span class="brand__logo brand__logo--sm" set:html={brandSvg} />
          <span>Recette <span style="color:#ec4899">Sauvage</span> · © {new Date().getFullYear()}</span>
        </div>
      </div>
    </footer>

    <style is:global>
      :root {
        --paper:#ece5d4; --accent:#4a6b48; --ink:#26301f; --ink2:#2f4a34; --ink3:#3a4533;
        --muted:#8a937a; --muted2:#6a7560; --line:rgba(47,74,52,0.16); --line-soft:rgba(47,74,52,0.14);
        --danger:#9c4a39; --danger2:#7e3729; --danger-bg:#f6ece6; --amber:#b07d3c; --card:#f7f4ea;
        --serif:'Spectral',Georgia,serif; --sans:'Hanken Grotesk',system-ui,-apple-system,sans-serif; --mono:'Spline Sans Mono',ui-monospace,monospace;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; }
      body {
        background: var(--paper);
        background-image: radial-gradient(rgba(74,107,72,0.05) 1px, transparent 1px);
        background-size: 22px 22px;
        color: var(--ink); font-family: var(--sans);
        -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;
      }
      a { color: inherit; }
      ::selection { background: rgba(74,107,72,0.22); }
      .site-nav { border-bottom: 1px solid var(--line); background: color-mix(in srgb, var(--paper) 84%, transparent); backdrop-filter: saturate(1.1) blur(6px); }
      .site-nav__inner { max-width: 1120px; margin: 0 auto; padding: 14px 32px; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
      .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
      .brand__logo { display: inline-flex; width: 42px; height: 42px; box-shadow: 0 4px 14px rgba(79,110,247,0.18); border-radius: 12px; }
      .brand__logo--sm { width: 24px; height: 24px; box-shadow: none; }
      .brand__logo svg { width: 100%; height: 100%; }
      .brand__txt { display: flex; flex-direction: column; line-height: 1; }
      .brand__name { font-weight: 700; font-size: 18px; letter-spacing: -0.3px; color: #16203a; }
      .brand__name--accent { background: linear-gradient(92deg, #ec4899, #4f6ef7); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
      .brand__tag { font-family: var(--mono); font-size: 8px; letter-spacing: 2.2px; text-transform: uppercase; color: #9aa1b4; margin-top: 4px; }
      .site-links { display: flex; gap: 6px; font-family: var(--mono); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; }
      .site-links a { text-decoration: none; color: var(--muted2); padding: 7px 11px; border-radius: 2px; transition: 0.2s; }
      .site-links a:hover { color: var(--ink2); background: rgba(47,74,52,0.08); }
      .site-footer { border-top: 1px solid var(--line); margin-top: 40px; }
      .site-footer__inner { max-width: 1120px; margin: 0 auto; padding: 30px 32px 56px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
      .avert { font-size: 13.5px; line-height: 1.6; color: var(--ink3); background: var(--card); border-left: 3px solid var(--danger); padding: 12px 16px; border-radius: 4px; margin: 0; max-width: 60ch; }
      .site-footer__brand { display: flex; align-items: center; gap: 9px; font-family: var(--sans); font-weight: 700; font-size: 14px; color: #16203a; }
      @media (max-width: 720px) { .site-nav__inner, .site-footer__inner { padding-left: 20px; padding-right: 20px; } }
    </style>
  </body>
</html>
